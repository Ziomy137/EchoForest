; Player.tscn — Player character scene for EchoForest.
;
; Scene tree structure:
;   Player              (CharacterBody2D) — root, PlayerControllerNode script
;   └── CollisionShape2D (CollisionShape2D) — CapsuleShape2D 4px radius / 8px height
;
; Physics configuration (matches PlayerCollisionConfig.cs):
;   collision_layer = 2  (bitmask for layer 2 = Player)
;   collision_mask  = 1  (bitmask for layer 1 = World)
;   motion_mode     = 0  (Grounded)
;
; Capsule shape (CapsuleShape2D):
;   radius = 4.0  — half the 16px sprite width (isometric-compressed)
;   height = 8.0  — lower portion of 24px sprite; total shape height = 16px
;
; Usage:
;   Instantiate Player.tscn in the Cottage test area and set its position
;   to PlayerSpawnPoint.global_position via GameBootstrap or scene init.
;
[gd_scene load_steps=4 format=3]

[ext_resource type="Script" path="res://src/Scripts/Core/PlayerControllerNode.cs" id="1"]
[ext_resource type="SpriteFrames" path="res://src/Assets/Animations/player_animations.tres" id="2_anim"]

[sub_resource type="CapsuleShape2D" id="3"]
radius = 4.0
height = 8.0

[node name="Player" type="CharacterBody2D"]
collision_layer = 2
collision_mask = 1
motion_mode = 0
script = ExtResource("1")

[node name="AnimatedSprite2D" type="AnimatedSprite2D" parent="."]
position = Vector2(0, -8)
scale = Vector2(1, 1)
sprite_frames = ExtResource("2_anim")
animation = &"idle_down"
autoplay = "idle_down"

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
shape = SubResource("3")
