; ── Scene tree ────────────────────────────────────────────────────────────────

[node name="MainMenu" type="CanvasLayer"]
layer = 5
script = ExtResource("1_script")

; Full-screen dark background — Deep Black #1a1a1a
[node name="Background" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.102, 0.102, 0.102, 1)

; Centered column with title + buttons
[node name="MenuContainer" type="CenterContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = SubResource("Theme_menu")

[node name="Layout" type="VBoxContainer" parent="MenuContainer"]
custom_minimum_size = Vector2(320, 0)
theme_override_constants/separation = 12

; Game title — Gold #ffd700
[node name="TitleLabel" type="Label" parent="MenuContainer/Layout"]
layout_mode = 2
text = "Echo Forest"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 52
theme_override_colors/font_color = Color(1.0, 0.843, 0.0, 1)

; Spacer between title and buttons
[node name="TitleSpacer" type="Control" parent="MenuContainer/Layout"]
layout_mode = 2
custom_minimum_size = Vector2(0, 20)

[node name="NewGameButton" type="Button" parent="MenuContainer/Layout"]
layout_mode = 2
text = "New Game"

; Continue is initially disabled — enabled by MainMenuNode when save exists
[node name="ContinueButton" type="Button" parent="MenuContainer/Layout"]
layout_mode = 2
text = "Continue"
disabled = true

[node name="LoadGameButton" type="Button" parent="MenuContainer/Layout"]
layout_mode = 2
text = "Load Game"

[node name="SettingsButton" type="Button" parent="MenuContainer/Layout"]
layout_mode = 2
text = "Settings"

[node name="CreditsButton" type="Button" parent="MenuContainer/Layout"]
layout_mode = 2
text = "Credits"

; Small visual separator before Exit
[node name="ExitSpacer" type="Control" parent="MenuContainer/Layout"]
layout_mode = 2
custom_minimum_size = Vector2(0, 8)

[node name="ExitButton" type="Button" parent="MenuContainer/Layout"]
layout_mode = 2
text = "Exit"

