; IsometricTileMap.tscn — Root scene for the isometric tile map system.
; TileMapLayer is the Godot 4.2+ replacement for the deprecated TileMap node.
;
; Scene tree structure:
;   IsometricTileMap      (Node2D)
;   └── TileMapLayer      (TileMapLayer) — references IsometricTileSet.tres
;
; Setup steps in Godot editor:
;   1. Open scene → select TileMapLayer node
;   2. Assign Tile Set → res://src/Assets/Data/IsometricTileSet.tres
;   3. Enable Y Sort on the parent Node2D (Inspector → Y Sort Enabled = true)
;   4. Confirm tile_set tile_shape = Isometric, size = 64×32
;
[gd_scene load_steps=2 format=3]

[ext_resource type="TileSet" path="res://src/Assets/Data/IsometricTileSet.tres" id="1"]

[node name="IsometricTileMap" type="Node2D"]
y_sort_enabled = true

[node name="TileMapLayer" type="TileMapLayer" parent="."]
tile_set = ExtResource("1")

[node name="TileMap" type="TileMap" parent="."]
tile_set = ExtResource("1")
format = 2
y_sort_enabled = true
